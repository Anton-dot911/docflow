# docflow-backend environment variables. Copy to .env and fill in real values;
# .env is gitignored and must never be committed.
# Load into commands with: uv run --env-file .env <command>
ANTHROPIC_API_KEY=
# Optional override for the llm client's default model.
# LLM_MODEL=

# --- Meter (LLM cost/latency tracking) -------------------------------------
# The llm layer records every model call to the shared Supabase `llm_calls`
# table via Meter. These are server-side only — never expose them to a browser.
# `llm_calls` has owner-only RLS that rejects anonymous inserts, so a
# write-capable service-role key is required to persist rows.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Recording is fire-and-forget: if these are unset (or an insert fails), Meter
# never breaks your llm call — it silently appends the record to a local
# ./meter.log.jsonl instead. No row reaches Supabase until both are set.
